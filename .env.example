# WHAT: Template for required environment variables. Copy to .env (gitignored).
# WHY:  Never commit real API keys (OWASP A02/A05, secrets-management).
# HOW:  Fireworks AI issues one API key per account; models are selected by ID.

FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1


FIREWORKS_MODEL_ORCHESTRATOR=accounts/fireworks/models/gpt-oss-120b
FIREWORKS_MODEL_SPECIALIST=accounts/fireworks/models/gpt-oss-120b
FIREWORKS_MODEL_RESEARCH=accounts/fireworks/models/gpt-oss-120b


# Local fallback (never assume single-provider availability)
LOCAL_LLAMA_TOOLS_URL=http://localhost:8009
LOCAL_LLAMA_CHAT_URL=http://localhost:8011
