# WHAT: Template for required environment variables. Copy to .env (gitignored).
# WHY:  Never commit real API keys (OWASP A02/A05, secrets-management).
# HOW:  Fireworks AI issues one API key per account; models are selected by ID.
#
# TROUBLESHOOTING (verified 2026-07-11): Fireworks' chat-completions endpoint
# returns HTTP 404 "Model not found, inaccessible, and/or not deployed" for
# a bad model ID, an invalid/missing key, AND a billing-suspended account —
# it does not distinguish the cause in that response. If EVERY model 404s,
# including well-known ones (e.g. llama-v3p1-70b-instruct), even after
# rotating FIREWORKS_API_KEY, check account status first:
#   curl -H "Authorization: Bearer $FIREWORKS_API_KEY" https://api.fireworks.ai/inference/v1/models
# A `412 PRECONDITION_FAILED` ("Account ... is suspended...") means the fix
# is at https://fireworks.ai/account/billing, not a code/key/model change.
# See README.md Troubleshooting for the full decision order.

FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

FIREWORKS_MODEL_ORCHESTRATOR=accounts/fireworks/models/gpt-oss-120b
FIREWORKS_MODEL_SPECIALIST=accounts/fireworks/models/gpt-oss-120b
FIREWORKS_MODEL_RESEARCH=accounts/fireworks/models/gpt-oss-120b

# # Model routing (Section 12.3 Model Routing Layer pattern) — override per agent.
# FIREWORKS_MODEL_ORCHESTRATOR=accounts/fireworks/models/llama-v3p1-70b-instruct
# FIREWORKS_MODEL_SPECIALIST=accounts/fireworks/models/qwen2p5-coder-32b-instruct
# FIREWORKS_MODEL_RESEARCH=accounts/fireworks/models/deepseek-v3p1

# Local fallback (never assume single-provider availability)
LOCAL_LLAMA_TOOLS_URL=http://localhost:8009
LOCAL_LLAMA_CHAT_URL=http://localhost:8011
