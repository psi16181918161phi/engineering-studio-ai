# WHAT: Normalizes line endings and marks generated/binary paths.
# WHY:  Prevents CRLF/LF churn across Windows/Linux contributors and CI.
# HOW:  Text files normalized to LF; binary/lockfiles marked explicitly.

* text=auto eol=lf

*.[Pp][Nn][Gg] binary
*.[Jj][Pp][Gg] binary
*.[Jj][Pp][Ee][Gg] binary
*.[Gg][Ii][Ff] binary
*.[Ii][Cc][Oo] binary
*.[Ww][Oo][Ff][Ff][2] binary

*.[Ll][Oo][Cc][Kk] -diff
[Pp][Aa][Cc][Kk][Aa][Gg][Ee]-[Ll][Oo][Cc][Kk].[Jj][Ss][Oo][Nn] -diff linguist-generated=true

*.[Mm][Dd] text eol=lf
*.[Mm][Dd][Xx] text eol=lf
*.[Tt][Xx][Tt] text eol=lf
*.[Cc][Ss][Vv] text eol=lf
*.[Yy][Mm][Ll] text eol=lf
*.[Yy][Aa][Mm][Ll] text eol=lf
*.[Tt][Oo][Mm][Ll] text eol=lf
*.[Xx][Mm][Ll] text eol=lf
*.[Hh][Tt][Mm][Ll] text eol=lf
*.[Cc][Ss][Ss] text eol=lf
*.[Ss][Cc][Ss][Ss] text eol=lf
*.[Ss][Vv][Gg] text eol=lf

# LFS: Large binary assets tracked via Git Large File Storage
